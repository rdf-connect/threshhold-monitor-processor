{
  "name": "@rdfc/threshold-monitor-processor-ts",
  "version": "0.0.0",
  "description": "RDF-Connect processor that monitors a float value at a configured SHACL path on incoming SDS members and emits an alert when it goes outside configured bounds.",
  "type": "module",
  "main": "lib/index.js",
  "files": [
    "lib/**/*",
    "processor.ttl"
  ],
  "scripts": {
    "build": "tsc && tsc-alias",
    "test": "vitest run --coverage --coverage.include src"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rdf-connect/threshold-monitor-processor-ts"
  },
  "license": "MIT",
  "dependencies": {
    "@rdfc/js-runner": "^3.1.0",
    "@treecg/types": "^0.4.6",
    "n3": "^2.1.1",
    "rdf-lens": "^1.3.7",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@rdfjs/types": "^2.0.1",
    "@types/n3": "^1.26.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "tsc-alias": "^1.9.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  }
}
